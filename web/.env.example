NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: required on deployed hosts for Admin → Users “Generate new password” (auth.admin.updateUserById).
# Supabase Dashboard → Project Settings → API → service_role (secret). Never use NEXT_PUBLIC_ or commit real values.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: image upload script — npm run generate:talent-images | generate-talent-images-free
# Flags: --kind=card|banner|both  --offset=N  --limit=N  (split across terminals)
# Auto: OpenAI if OPENAI_API_KEY is set, else Pollinations (free, no key — rate limits apply).
# IMAGE_GEN_PROVIDER=pollinations   # AI, often 429
# IMAGE_GEN_PROVIDER=picsum         # stock photos, reliable demos (npm run generate-talent-images-stock)
# IMAGE_GEN_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# Optional: Phase 9 — `npm run embed-talents`; with `ai_search_enabled` the public directory uses `POST /api/ai/search` (hybrid). `ai_refine_enabled` shows refine chips (`POST /api/ai/refine-suggestions`).
# Same key as image scripts; uses text-embedding-3-small (1536-dim).
#
# --- AI chat provider (NLU, inquiry draft, translations, interpret-search) ---
# If `usedInterpreter` is always false, check API field `interpretFailureCode` and server logs (`interpret_search_*`).
# Common: `no_key` (DB `ai_provider` must match which of OPENAI_API_KEY / ANTHROPIC_API_KEY is set).
# Default provider is OpenAI; Admin → AI Settings can set `ai_provider` in the DB to `anthropic`.
# Optional: force provider regardless of DB (openai | anthropic).
# AI_PROVIDER=openai
# When using Anthropic (Claude), set:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_CHAT_MODEL=claude-sonnet-4-20250514
# Optional: chat model for OpenAI paths. Default: gpt-4o-mini
# OPENAI_CHAT_MODEL=gpt-4o-mini
# OPENAI_IMAGE_MODEL=dall-e-3
# POLLINATIONS_MODEL=flux   # optional; see pollinations.ai
# POLLINATIONS_DELAY_MS=7000   # pause between images (free tier / 429)
# POLLINATIONS_MAX_RETRIES=10  # retries per image on 429/502/503
# Used in auth callbacks and OAuth redirects (no trailing slash).
# On Vercel, set to your deployment URL (https://…), not localhost.
NEXT_PUBLIC_SITE_URL=http://localhost:4000

# --- Analytics (optional) ---
# GA4 browser tag (public). Consent banner controls storage; modeled data may apply when denied.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# GA4 Data API + Realtime (server-only JSON service account key — never commit).
# GA4_PROPERTY_ID=123456789
# GOOGLE_ANALYTICS_CREDENTIALS_JSON={"type":"service_account",...}
# Google Search Console API (same or separate service account with Search Console permission).
# GSC_SITE_URL=https://www.example.com/
# GOOGLE_SEARCH_CONSOLE_CREDENTIALS_JSON={"type":"service_account",...}

# Optional: `npm run verify:deploy-env` with DEPLOY_ENV_STRICT=1 also requires NEXT_PUBLIC_SITE_URL
# (use before pushing to Vercel so OAuth/metadata are correct).
# DEPLOY_ENV_STRICT=1

# --- Google Places (country + city autocomplete in canonical location fields; server-side only) ---
# Console: https://console.cloud.google.com/google/maps-apis
# 1) Enable billing on the project.
# 2) Enable "Places API" (legacy Autocomplete + Place Details endpoints used by the app).
# 3) Create an API key; Application restriction: "None" (dev) or "IP addresses" (production server).
#    Avoid "HTTP referrers" for this key — Places calls are made from Node, not the browser.
# 4) Copy the key here. You do NOT need the Maps "URL signing secret" for this feature.
GOOGLE_PLACES_API_KEY=
# Optional: BCP-47 language for Places text (default en)
# GOOGLE_PLACES_LANGUAGE=en

# Optional: when `1`, missing `settings` rows default directory + inquiries to **closed** (stricter prod).
# Default: unset (missing keys keep directory/inquiries open until admins seed toggles).
# PUBLIC_SETTINGS_STRICT_MISSING=1

# Optional: force legacy client-assembled directory search (skip Postgres RPC). For local debugging or
# emergency rollback without redeploying. Default: unset (use RPC `directory_search_public_talent_ids`).
# DIRECTORY_SEARCH_FORCE_LEGACY=1

# Optional: JSON timing logs for `/api/directory` + `fetchDirectoryPage` (stdout). For performance audits only.
# DIRECTORY_API_AUDIT=1

# Optional: local verification scripts (never commit real passwords)
# TALENT_EMAIL=talent@example.com
# TALENT_PASSWORD=your-test-password

# --- Super-admin workspace impersonation (QA talent/client dashboards; v1 read-only) ---
# Random secret (e.g. openssl rand -hex 32). Required to set/sign the HttpOnly cookie.
# IMPERSONATION_COOKIE_SECRET=
# UUIDs of real users (profiles.id = auth.users.id) with app_role talent / client, account active.
# IMPERSONATION_QA_TALENT_USER_ID=
# IMPERSONATION_QA_CLIENT_USER_ID=
