{
  "$schema": "./canonical-flow.schema.json",
  "version": "1.0.0",
  "purpose": "Single source of truth for how an inquiry → offer → hold → booking → post-shoot flow renders across all 3 surfaces (Workspace admin/coordinator · Talent · Client). Use this fixture to drive prototype data, design reviews, QA scripts, and eventually production seed data.",

  "_legend": {
    "actors": "Every human or org in the flow with their role + permissions",
    "threads": "Conversation channels — who can read, who can post",
    "stages": "Lifecycle states the inquiry passes through",
    "events": "Timeline of what happened, with actor + payload + per-surface visibility"
  },

  "actors": {
    "client_brand": {
      "id": "br-mango",
      "name": "Mango",
      "type": "brand",
      "trustLevel": "verified",
      "industry": "Fashion · ready-to-wear",
      "members": [
        {
          "id": "u-joana",
          "name": "Joana Rivera",
          "role": "brand_manager",
          "title": "Brand Manager",
          "email": "joana@mango.com",
          "permissions": ["create_inquiry", "approve_offer", "sign_booking", "pay_invoice", "message_coordinator"]
        }
      ]
    },
    "agency": {
      "id": "ag-acme",
      "name": "Acme Models",
      "type": "agency",
      "plan": "studio",
      "settings": {
        "auto_assign_owner_as_coordinator": true,
        "allow_talent_direct_chat": false,
        "talent_can_add_crew": false
      },
      "members": [
        {
          "id": "u-marta-owner",
          "name": "Marta Reyes",
          "role": "owner",
          "permissions": ["all"]
        },
        {
          "id": "u-sara-coord",
          "name": "Sara Bianchi",
          "role": "coordinator",
          "permissions": [
            "assign_self",
            "add_remove_talent",
            "send_offer",
            "edit_brief",
            "message_client",
            "message_talent_group",
            "build_call_sheet"
          ]
        }
      ]
    },
    "talents": [
      {
        "id": "t-marta",
        "name": "Marta Reyes",
        "agency_id": "ag-acme",
        "thumb": "🌸",
        "permissions": ["accept_decline", "message_coordinator", "view_own_thread", "view_group_thread"]
      },
      {
        "id": "t-tomas",
        "name": "Tomás Navarro",
        "agency_id": "ag-acme",
        "thumb": "🍃",
        "permissions": ["accept_decline", "message_coordinator", "view_own_thread", "view_group_thread"]
      },
      {
        "id": "t-zara",
        "name": "Zara Habib",
        "agency_id": "ag-acme",
        "thumb": "🌹",
        "permissions": ["accept_decline", "message_coordinator", "view_own_thread", "view_group_thread"]
      }
    ]
  },

  "threads": {
    "client_thread": {
      "id": "th-client",
      "name": "Client thread",
      "purpose": "1:1 (or 1:few) between the client and the agency-side (admin + coordinator). Talent NEVER sees this thread unless they are the coordinator (hub freelancer case).",
      "participants": ["br-mango/u-joana", "ag-acme/u-marta-owner", "ag-acme/u-sara-coord"],
      "visible_to": {
        "client_pov": "yes — main thread",
        "agency_admin_pov": "yes — left tab \"Client thread\"",
        "talent_pov": "no — never visible"
      }
    },
    "talent_group_thread": {
      "id": "th-talent-group",
      "name": "Talent group",
      "purpose": "Coordinator + admin + invited talents. The booking team. Client cannot see.",
      "participants": ["ag-acme/u-marta-owner", "ag-acme/u-sara-coord", "t-marta", "t-tomas", "t-zara"],
      "visible_to": {
        "client_pov": "no — never visible",
        "agency_admin_pov": "yes — middle tab \"Talent group\"",
        "talent_pov": "yes — main thread (their only inbox view of this booking)"
      }
    },
    "agency_internal_thread": {
      "id": "th-internal",
      "name": "Agency internal",
      "purpose": "Admin ↔ coordinator side notes. Optional. Never visible to client or talent.",
      "participants": ["ag-acme/u-marta-owner", "ag-acme/u-sara-coord"],
      "visible_to": {
        "client_pov": "no",
        "agency_admin_pov": "yes — overflow tab",
        "talent_pov": "no"
      }
    }
  },

  "stages": [
    { "id": "submitted",     "label": "Submitted",     "color": "coral",  "meaning": "Client filed an inquiry. Agency hasn't picked it up yet." },
    { "id": "coordination",  "label": "Coordinating",  "color": "coral",  "meaning": "Coordinator assigned, working on shortlist." },
    { "id": "offer_pending", "label": "Offer sent",    "color": "amber",  "meaning": "Coordinator sent a structured offer. Awaiting client approval." },
    { "id": "approved",      "label": "Approved",      "color": "amber",  "meaning": "Client approved offer. Booking being prepared." },
    { "id": "booked",        "label": "Booked",        "color": "green",  "meaning": "Booking confirmed. Call sheet ready, contracts signed." },
    { "id": "completed",     "label": "Completed",     "color": "muted",  "meaning": "Shoot wrapped. Selects shared. Invoice paid." },
    { "id": "rejected",      "label": "Declined",      "color": "muted",  "meaning": "Client declined offer." },
    { "id": "expired",       "label": "Expired",       "color": "muted",  "meaning": "Offer or hold expired without action." }
  ],

  "scenario": {
    "id": "RI-201",
    "title": "Mango · Spring lookbook · 3 talent · 1 day",
    "shoot_date": "2026-05-06",
    "location": "Madrid · Calle de Velázquez 18 · Estudio Roca",
    "actors_involved": ["br-mango/u-joana", "ag-acme/u-marta-owner", "ag-acme/u-sara-coord", "t-marta", "t-tomas", "t-zara"],

    "timeline": [
      {
        "step": 1,
        "stage": "submitted",
        "ts": "2026-04-22T16:42:00Z",
        "event": "client_creates_inquiry",
        "actor": "br-mango/u-joana",
        "payload": {
          "brief": "Spring lookbook — need 3 talents who can handle high-fashion editorial, ideally with runway experience.",
          "date": "2026-05-06",
          "location": "Madrid · Estudio Roca",
          "budget_per_talent_per_day_eur": 2500
        },
        "thread": "th-client",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "title": "Mango",
            "subtitle": "Spring lookbook · 3 talent · 1 day",
            "stage_pill": "Inquiry",
            "preview": "Inquiry sent. A coordinator will respond within 2 hours.",
            "unread_badge": 0,
            "participants_stack": ["JR (you)"]
          },
          "agency_admin_inbox_row": {
            "title": "Mango",
            "subtitle": "Spring lookbook · 3 talent · 1 day",
            "stage_pill": "Submitted",
            "preview": "New inquiry from Mango — needs coordinator assignment.",
            "needs_me_chip": "Coordinator",
            "unread_badge": 1
          },
          "talent_inbox_row": "not visible (talent not yet invited)"
        }
      },
      {
        "step": 2,
        "stage": "coordination",
        "ts": "2026-04-22T16:55:00Z",
        "event": "owner_assigns_coordinator",
        "actor": "ag-acme/u-marta-owner",
        "payload": { "coordinator_id": "ag-acme/u-sara-coord" },
        "thread": "th-internal",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "preview": "Sara Bianchi assigned as your coordinator — she'll be in touch shortly.",
            "system_event": true
          },
          "agency_admin_inbox_row": {
            "stage_pill": "Coordinating",
            "preview": "Sara assigned (you assigned)."
          }
        }
      },
      {
        "step": 3,
        "stage": "coordination",
        "ts": "2026-04-22T16:58:00Z",
        "event": "coordinator_replies_to_client",
        "actor": "ag-acme/u-sara-coord",
        "payload": { "message": "Got it — pulling 3 candidates. Marta's already a soft yes. Will share the lineup and rates within 2 hrs." },
        "thread": "th-client",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "preview": "Sara Bianchi: Got it — pulling 3 candidates. Marta's already a soft yes…",
            "unread_badge": 1
          },
          "agency_admin_inbox_row": {
            "preview": "You: Got it — pulling 3 candidates. Marta's already a soft yes…"
          },
          "coordinator_inbox_row": "same as agency_admin"
        }
      },
      {
        "step": 4,
        "stage": "coordination",
        "ts": "2026-04-22T17:10:00Z",
        "event": "coordinator_invites_talents",
        "actor": "ag-acme/u-sara-coord",
        "payload": { "talent_ids": ["t-marta", "t-tomas", "t-zara"] },
        "thread": "th-talent-group",
        "what_each_surface_sees": {
          "client_inbox_row": "no change",
          "agency_admin_inbox_row": {
            "preview": "Talent group: 3 invited (Marta · Tomás · Zara) — awaiting confirmations.",
            "participants_stack": ["MR", "TN", "ZH"]
          },
          "talent_inbox_row": {
            "title": "Mango (via Acme Models)",
            "subtitle": "Spring lookbook · Madrid · May 6",
            "stage_pill": "Inquiry",
            "preview": "Sara Bianchi invited you to this booking. Please confirm availability.",
            "unread_badge": 1,
            "participants_stack": ["SB (coord)", "MR", "TN", "ZH"]
          }
        }
      },
      {
        "step": 5,
        "stage": "coordination",
        "ts": "2026-04-22T17:22:00Z",
        "event": "talent_confirms_availability",
        "actor": "t-marta",
        "payload": { "status": "available", "message": "All clear from me — happy to confirm." },
        "thread": "th-talent-group",
        "what_each_surface_sees": {
          "agency_admin_inbox_row": {
            "preview": "Marta Reyes: All clear from me — happy to confirm.",
            "approved_count": "1/3"
          },
          "talent_inbox_row_for_marta": "her status is now 'accepted'"
        }
      },
      {
        "step": 6,
        "stage": "coordination",
        "ts": "2026-04-23T10:01:00Z",
        "event": "talent_replies_pending",
        "actor": "t-tomas",
        "payload": { "status": "checking", "message": "Checking my schedule — back in 1h." },
        "thread": "th-talent-group"
      },
      {
        "step": 7,
        "stage": "coordination",
        "ts": "2026-04-23T11:30:00Z",
        "event": "client_message_to_coordinator",
        "actor": "br-mango/u-joana",
        "payload": { "message": "Perfect. We're flexible on talent #3. Budget cap is €2,500/day each." },
        "thread": "th-client"
      },
      {
        "step": 8,
        "stage": "offer_pending",
        "ts": "2026-04-23T12:00:00Z",
        "event": "coordinator_sends_offer",
        "actor": "ag-acme/u-sara-coord",
        "payload": {
          "offer": {
            "talent_lineup": [
              { "id": "t-marta", "rate_eur": 2400 },
              { "id": "t-tomas", "rate_eur": 2200 }
            ],
            "agency_fee_eur": 600,
            "studio_pass_through_eur": 800,
            "total_eur": 8000,
            "expires_at": "2026-04-24T12:00:00Z",
            "usage": "Digital · 12 months · Spain only"
          }
        },
        "thread": "th-client",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "stage_pill": "Hold (offer pending)",
            "preview": "Offer sent — €8,000 total · 2 talent · expires Apr 24",
            "needs_me_chip": "Approve offer",
            "action_card": { "label": "Approve offer", "primary": true }
          },
          "agency_admin_inbox_row": {
            "stage_pill": "Hold (offer pending)",
            "preview": "You: Offer sent — awaiting client approval.",
            "sla_timer": "23h 58m"
          },
          "talent_inbox_row_for_marta_and_tomas": {
            "stage_pill": "Hold",
            "preview": "Offer sent to client — awaiting their approval. You're in the lineup."
          }
        }
      },
      {
        "step": 9,
        "stage": "approved",
        "ts": "2026-04-23T15:30:00Z",
        "event": "client_approves_offer",
        "actor": "br-mango/u-joana",
        "payload": { "approved": true },
        "thread": "th-client",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "stage_pill": "Approved",
            "preview": "Approved — agency will send the call sheet.",
            "action_card": { "label": "Sign booking", "primary": true }
          },
          "agency_admin_inbox_row": {
            "stage_pill": "Approved",
            "preview": "Mango approved offer · €8,000",
            "needs_me_chip": "Build call sheet"
          },
          "talent_inbox_row": {
            "stage_pill": "Booked (pending call sheet)",
            "preview": "Client approved. Call sheet incoming — block May 6."
          }
        }
      },
      {
        "step": 10,
        "stage": "booked",
        "ts": "2026-04-24T09:15:00Z",
        "event": "coordinator_publishes_call_sheet",
        "actor": "ag-acme/u-sara-coord",
        "payload": {
          "call_sheet": {
            "shoot_date": "2026-05-06",
            "call_time": "08:00",
            "wrap_by": "18:00",
            "location": "Madrid · Calle de Velázquez 18 · Estudio Roca",
            "transport": "Taxi covered — confirm pickup time with coordinator",
            "hmu": "Nia Clarkson (8:00–10:30)",
            "photographer": "Lucas Ferreira",
            "wardrobe": "Provided · seamstress on site"
          }
        },
        "thread": "th-talent-group",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "stage_pill": "Booked",
            "preview": "Call sheet published. We're set for May 6.",
            "info_panel": { "shoot_date": "May 6", "call_time": "08:00", "location": "Estudio Roca" }
          },
          "agency_admin_inbox_row": {
            "stage_pill": "Booked",
            "preview": "Call sheet sent to talent + client."
          },
          "talent_inbox_row": {
            "stage_pill": "Booked",
            "preview": "Call sheet attached. HMU at 06:30, on set 07:00. Confirm receipt.",
            "pinned_info": {
              "schedule": "May 6 · call 08:00 · wrap by 18:00",
              "location": "Madrid · Calle de Velázquez 18",
              "transport": "Taxi covered",
              "rate": "€2,400 to you (gross)"
            }
          }
        }
      },
      {
        "step": 11,
        "stage": "booked",
        "ts": "2026-05-06T07:30:00Z",
        "event": "talent_check_in_on_set",
        "actor": "t-marta",
        "payload": { "checked_in": true, "ts": "07:28" },
        "thread": "th-talent-group",
        "what_each_surface_sees": {
          "agency_admin_inbox_row": { "preview": "Marta checked in on set · 07:28" },
          "talent_inbox_row_for_marta": { "preview": "You checked in · 07:28" },
          "client_inbox_row": "system event: \"Talent on set\" notification (optional)"
        }
      },
      {
        "step": 12,
        "stage": "completed",
        "ts": "2026-05-06T18:30:00Z",
        "event": "shoot_wrapped",
        "actor": "ag-acme/u-sara-coord",
        "payload": { "selects_to_share_by": "2026-05-13" },
        "thread": "th-client",
        "what_each_surface_sees": {
          "client_inbox_row": {
            "stage_pill": "Completed",
            "preview": "Wrap. Selects landing by May 13.",
            "action_card": { "label": "Pay invoice (€8,000)", "primary": true }
          },
          "agency_admin_inbox_row": {
            "stage_pill": "Completed",
            "preview": "Wrap. Invoice issued · awaiting payment."
          },
          "talent_inbox_row": {
            "stage_pill": "Completed",
            "preview": "Booking wrapped. Selects shared. Payout date: May 22."
          }
        }
      }
    ]
  },

  "permissions_matrix": {
    "_note": "Who can do what at each stage. Admin always trumps. Coordinator's add/remove talent gated by setting `talent_can_add_crew`. Talent direct-chat gated by `allow_talent_direct_chat`.",
    "rows": [
      ["action",                       "agency_owner", "agency_coordinator", "talent",    "client",  "talent_as_coordinator (hub)"],
      ["create_inquiry",               "—",            "—",                   "—",         "yes",     "—"],
      ["assign_coordinator",           "yes",          "self_only",           "—",         "—",       "—"],
      ["edit_brief",                   "yes",          "yes",                 "no",        "yes",     "yes"],
      ["invite_talent_to_inquiry",     "yes",          "yes",                 "no",        "no",      "yes (own circle)"],
      ["remove_talent_from_inquiry",   "yes",          "yes",                 "no",        "no",      "no"],
      ["message_in_client_thread",     "yes",          "yes",                 "no",        "yes",     "yes if setting on"],
      ["message_in_talent_group",      "yes",          "yes",                 "yes",       "no",      "yes"],
      ["send_offer",                   "yes",          "yes",                 "no",        "—",       "yes if setting on"],
      ["approve_offer",                "—",            "—",                   "—",         "yes",     "—"],
      ["build_call_sheet",             "yes",          "yes",                 "no",        "no",      "yes"],
      ["check_in_on_set",              "yes",          "yes",                 "self_only", "no",      "self_only"],
      ["mark_completed",               "yes",          "yes",                 "no",        "no",      "yes"],
      ["pay_invoice",                  "—",            "—",                   "—",         "yes",     "—"],
      ["receive_payout",               "—",            "—",                   "yes",       "—",      "yes"]
    ]
  },

  "inbox_row_anatomy": {
    "_note": "Every row in the unified MessagesInquiryRow component, regardless of pov, has these fields. The pov controls how `title`, `subtitle`, `preview`, `participants_stack` are computed.",
    "fields": {
      "client_avatar":      { "size": 40, "trust_badge_overlay": true, "tone": "auto" },
      "title":              { "max_chars": 32, "truncate": true, "client_pov": "client name", "talent_pov": "client (via agency name)", "admin_pov": "client name" },
      "age_label":          { "format": "{N}h | {N}d | now" },
      "subtitle_brief":     { "max_chars": 48, "truncate": true, "format": "{brief} · {talent_count} talent · {duration}" },
      "stage_pill":         { "shape": "pill 999px", "case": "Sentence case", "tones_by_stage": "see stages.color" },
      "preview_message":    { "max_chars": 80, "truncate": true, "you_prefix": "You: " },
      "unread_badge":       { "shape": "circle 16px", "color": "accent", "max_display": "9+" },
      "participants_stack": { "max_avatars": 5, "overflow": "+N" }
    }
  },

  "thread_view_per_pov": {
    "agency_admin_pov": {
      "header": "client name + trust badge + status chip + 🔍 + ⋮",
      "tabs": ["Client thread", "Talent group", "Files"],
      "details_rail": ["Brief / Date / Location", "Coordinator card", "Talent lineup with status", "Offer summary", "Activity log"]
    },
    "talent_pov": {
      "header": "client name + status chip + 🔍 + ⋮",
      "tabs": "single thread (talent_group_thread only)",
      "details_rail": ["Schedule (call time / wrap / date)", "Location + Maps link", "Transport", "Coordinator (leader)", "Crew on shoot", "Rate / amount-to-you", "AI summary"]
    },
    "client_pov": {
      "header": "agency name + agency trust badge + status chip + 🔍 + ⋮",
      "tabs": "single thread (client_thread only)",
      "details_rail": ["Coordinator card", "Brief summary (editable)", "Talent lineup (read-only)", "Schedule + Location", "Offer / approval summary", "Invoice + payment status"]
    }
  },

  "open_questions": [
    {
      "q": "When `auto_assign_owner_as_coordinator` is OFF and no talent is assigned coordinator yet, who triages the inbound inquiry?",
      "options": ["Round-robin to next available coordinator", "Stays unassigned (queue)", "Owner gets a fallback assignment"]
    },
    {
      "q": "Hub freelancer scenario: a chef is contacted directly. They ARE the coordinator. Can they invite their own crew (e.g., sous chef, server)?",
      "options": ["Always yes", "Only if hub setting allows", "Only from their Circle"]
    },
    {
      "q": "What does the client see when an offer is rejected by talent (talent declines invite)?",
      "options": ["System message: \"Coordinator is finding alternatives\"", "Nothing — only after coordinator decides", "Client sees the lineup change in real time"]
    },
    {
      "q": "Can the client message a specific talent directly (e.g., asking about a previous shoot)?",
      "options": ["Never — always through coordinator", "Yes if talent + agency both allow", "Yes after booking is confirmed"]
    }
  ]
}
