{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev --webpack -p ${PORT:-3000}",
    "build": "next build",
    "start": "next start",
    "lint": "node -r ./scripts/eslint-node-polyfill.cjs ./node_modules/eslint/bin/eslint.js .",
    "typecheck": "tsc --noEmit",
    "verify:server-actions": "node scripts/check-server-actions.mjs",
    "ci": "npm run typecheck && npm run verify:server-actions && npm run test:phase1-i18n && npm run test:locale-precedence && npm run test:inquiry-workspace && npm run test:ai-guardrails && npm run test:tenant-isolation && npm run verify:ui-messages && npm run lint && npm run build",
    "test:auth-routing": "tsx --test src/lib/auth-routing.test.ts",
    "test:tenant-isolation": "tsx --test src/lib/saas/admin-scope.test.ts src/lib/saas/scope.test.ts src/lib/saas/tenant-isolation.test.ts src/lib/saas/surface-allow-list.test.ts",
    "test:phase1-i18n": "tsx --test src/lib/translation/phase1-invariants.test.ts",
    "test:locale-precedence": "tsx --test src/i18n/locale-precedence.test.ts",
    "test:inquiry-workspace": "tsx --test src/lib/inquiry/inquiry-workspace.test.ts",
    "validate:inquiry-workspace-db": "node --env-file=.env.local scripts/validate-inquiry-workspace-db.mjs",
    "test:ai-guardrails": "tsx --test src/lib/ai/inquiry-draft-guardrails.test.ts src/lib/ai/resolve-location-from-query.test.ts src/lib/ai/interpret-taxonomy-synonyms.test.ts src/lib/ai/deterministic-gender-taxonomy.test.ts",
    "create:test-clients": "node --env-file=.env.local scripts/create-test-clients.mjs",
    "create:test-admin": "node --env-file=.env.local scripts/create-test-admin.mjs",
    "seed:phase5-qa": "node --env-file=.env.local scripts/seed-phase5-qa.mjs",
    "register:tulum-demo-talent": "node --env-file=.env.local scripts/register-tulum-demo-talent.mjs",
    "verify:dashboard-users": "node scripts/verify-dashboard-users.mjs",
    "verify:talent-submission-reads": "node scripts/verify-talent-submission-reads.mjs",
    "verify:talent-nav-groups": "node scripts/verify-talent-nav-groups.mjs",
    "verify:profile-remediation": "node scripts/verify-profile-remediation.mjs",
    "verify:profile-anon-smoke": "node scripts/verify-profile-anon-smoke.mjs",
    "verify:ui-messages": "node scripts/check-ui-messages.mjs",
    "verify:google-maps-env": "node --env-file=.env.local scripts/verify-google-maps-env.mjs",
    "verify:deploy-env": "node scripts/verify-deploy-env.mjs",
    "verify:deploy-env:strict": "DEPLOY_ENV_STRICT=1 node --env-file=.env.local scripts/verify-deploy-env.mjs",
    "generate:talent-images": "node --env-file=.env.local scripts/generate-talent-portrait-images.mjs",
    "generate-talent-images-free": "IMAGE_GEN_PROVIDER=pollinations node --env-file=.env.local scripts/generate-talent-portrait-images.mjs",
    "generate-talent-images-stock": "IMAGE_GEN_PROVIDER=picsum node --env-file=.env.local scripts/generate-talent-portrait-images.mjs",
    "generate-talent-images-dry-run": "node --env-file=.env.local scripts/generate-talent-portrait-images.mjs --dry-run",
    "embed-talents": "node --env-file=.env.local scripts/embed-talents.mjs",
    "rebuild-ai-documents": "tsx --env-file=.env.local scripts/rebuild-ai-documents.ts",
    "eval:search": "tsx --env-file=.env.local scripts/eval-search.ts",
    "qa:interpret-search": "node scripts/qa-interpret-search.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google-analytics/data": "4.12.1",
    "@next/third-parties": "16.2.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-id": "1.1.1",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.102.1",
    "@tanstack/react-query": "^5.96.2",
    "@vis.gl/react-google-maps": "^1.8.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "framer-motion": "^12.38.0",
    "googleapis": "144.0.0",
    "iceberg-js": "^0.8.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.3",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-easy-crop": "^5.5.7",
    "resend": "^6.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "embedded-postgres": "^17.9.0-beta.17",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "libphonenumber-js": "^1.11.20",
    "pg": "^8.20.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
