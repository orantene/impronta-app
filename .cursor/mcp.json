{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--extension"]
    },
    "supabase": {
      "url": "https://mcp.supabase.com/mcp?read_only=true&project_ref=pluhdapdnuiulvxmyspd"
    },
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "ghcr.io/github/github-mcp-server"
      ],
      "envFile": "${workspaceFolder}/.cursor/github-mcp.env"
    }
  }
}
